rules_version = '2';

// Primeira versão das regras, baseada na seção 5/"Esboço de Security Rules"
// do documento docs/schema-banco-dados-personagem.md.
//
// Fase Campanha (criar/entrar) já implementada abaixo. AINDA NÃO INCLUI:
// acesso do Mestre às fichas de personagem da própria campanha -- isso
// depende do campo `campanha_id`/`campanhas_ids` em `personagens`, que só
// entra na fase "Personagem dentro da Mesa". Os TODOs no bloco de
// personagens marcam exatamente onde essa lógica vai entrar.
//
// IMPORTANTE: por enquanto, o dono do personagem pode escrever em QUALQUER
// campo da própria ficha, incluindo `calculado` — o ideal é que só a Cloud
// Function (via Admin SDK, que ignora estas regras) escreva ali. Restringir
// isso por campo dentro do Firestore Rules é possível mas mais avançado;
// fica como endurecimento futuro (ver TODO no bloco de personagens).

service cloud.firestore {
  match /databases/{database}/documents {

    function estaAutenticado() {
      return request.auth != null;
    }

    function ehDono(donoUid) {
      return estaAutenticado() && request.auth.uid == donoUid;
    }

    // ---- Catálogo do sistema de regras: leitura livre, escrita só via admin/seed ----
    match /racas/{racaId} {
      allow read: if estaAutenticado();
      allow write: if false;
    }
    match /classes/{classeId} {
      allow read: if estaAutenticado();
      allow write: if false;
    }
    match /origens/{origemId} {
      allow read: if estaAutenticado();
      allow write: if false;
    }
    match /pericias/{periciaId} {
      allow read: if estaAutenticado();
      allow write: if false;
    }
    match /elementos/{elementoId} {
      allow read: if estaAutenticado();
      allow write: if false;

      match /poderes/{poderId} {
        allow read: if estaAutenticado();
        allow write: if false;
      }
    }
    match /itens/{itemId} {
      allow read: if estaAutenticado();
      allow write: if false;
    }
    match /constantes/{constanteId} {
      allow read: if estaAutenticado();
      allow write: if false;
    }

    // ---- Perfil do usuário ----
    match /usuarios/{uid} {
      allow read, write: if ehDono(uid);
    }

    // ---- Campanhas ----
    match /campanhas/{campanhaId} {
      // Leitura aberta a qualquer usuário autenticado: quem vai entrar com
      // um código de convite precisa conseguir localizar a campanha pelo
      // `codigo_convite` ANTES de fazer parte de `jogadores_uids`.
      allow read: if estaAutenticado();

      allow create: if estaAutenticado()
        && request.resource.data.mestre_id == request.auth.uid
        && request.resource.data.jogadores_uids == []
        && request.resource.data.nome is string
        && request.resource.data.nome.size() > 0;

      // O mestre pode atualizar qualquer campo. Quem não é mestre só pode
      // alterar `jogadores_uids` (e `atualizado_em` junto) e apenas para
      // ADICIONAR o próprio uid -- nunca remover ou adicionar outra pessoa,
      // nem tocar em nome/descrição/imagem/mestre_id/codigo_convite.
      allow update: if estaAutenticado() && (
        ehDono(resource.data.mestre_id)
        || (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['jogadores_uids', 'atualizado_em'])
          && request.resource.data.jogadores_uids.hasAll(resource.data.jogadores_uids)
          && request.resource.data.jogadores_uids.hasOnly(resource.data.jogadores_uids.concat([request.auth.uid]))
        )
      );

      allow delete: if ehDono(resource.data.mestre_id);
    }

    // ---- Encontros de combate ----
    // Cada encontro pertence a UMA campanha e é de uso exclusivo do
    // mestre_id dela -- diferente de `campanhas`, aqui não existe leitura
    // aberta pra todo autenticado, porque não há um fluxo de "entrar por
    // código" equivalente. Guardamos mestre_id direto no próprio documento
    // (em vez de fazer o cliente cruzar com /campanhas/{id}) porque
    // Firestore Rules não conseguem fazer join eficiente; isso espelha o
    // mesmo motivo por trás de `mestre_campanha_personagens.py` no backend.
    match /encontros/{encontroId} {
      allow read, update, delete: if ehDono(resource.data.mestre_id);
      allow create: if ehDono(request.resource.data.mestre_id);
    }

    // ---- Fichas de personagem ----
    match /personagens/{personagemId} {
      allow read: if ehDono(resource.data.dono_uid);
      allow create: if ehDono(request.resource.data.dono_uid);
      allow update, delete: if ehDono(resource.data.dono_uid);

      // TODO (fase Campanha): permitir leitura total ao mestre_id da
      // campanha à qual este personagem pertence.
      // TODO (fase Campanha): permitir ao mestre escrever somente em
      // ascensao_em_progresso.status (aprovar/recusar), nada mais.
      // TODO (endurecimento): restringir escrita do dono para excluir o
      // bloco `calculado`, que deveria ser exclusivo da Cloud Function.
    }
  }
}
