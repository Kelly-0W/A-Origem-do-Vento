rules_version = '2';

// Primeira versão das regras, baseada na seção 5/"Esboço de Security Rules"
// do documento docs/schema-banco-dados-personagem.md.
//
// Fase Campanha (criar/entrar) já implementada abaixo.
//
// Painel do Mestre (Fase 4 -- ver pedidos de Ascensão e fichas de todos os
// personagens de uma campanha): NÃO foi resolvido adicionando regras aqui.
// Um mestre precisa ler/editar personagens de que NÃO é dono, e a checagem
// "esse uid é mestre_id de alguma campanha cujo id está no array
// campanhas_ids deste personagem" exigiria percorrer um array de tamanho
// variável fazendo um get() por item -- o Firestore Rules não suporta essa
// forma de laço. Por isso esse acesso passa por dois endpoints com Admin
// SDK (que ignoram estas regras de propósito):
//   - api/mestre_campanha_personagens.py (leitura: lista a mesa inteira)
//   - api/responder_ascensao.py (escrita: aprova/recusa e recalcula a ficha)
// Ambos conferem no servidor que quem chamou é de fato o mestre_id da
// campanha antes de fazer qualquer leitura/escrita.
//
// IMPORTANTE: por enquanto, o dono do personagem pode escrever em QUALQUER
// campo da própria ficha, incluindo `calculado` — o ideal é que só uma
// Cloud Function (via Admin SDK, que ignora estas regras) escreva ali.
// Restringir isso por campo dentro do Firestore Rules é possível mas mais
// avançado; fica como endurecimento futuro (ver TODO no bloco de
// personagens). Os 3 booleans + descrição de `ascensao_em_progresso` já
// aproveitam essa permissividade de propósito (é o próprio jogador quem
// marca Catalisador/Provação/Ritual, client-side, direto no documento).

service cloud.firestore {
  match /databases/{database}/documents {

    function estaAutenticado() {
      return request.auth != null;
    }

    function ehDono(donoUid) {
      return estaAutenticado() && request.auth.uid == donoUid;
    }

    // ---- Catálogo do sistema de regras: leitura livre, escrita só via admin/seed ----
    match /racas/{racaId} {
      allow read: if estaAutenticado();
      allow write: if false;
    }
    match /classes/{classeId} {
      allow read: if estaAutenticado();
      allow write: if false;
    }
    match /origens/{origemId} {
      allow read: if estaAutenticado();
      allow write: if false;
    }
    match /pericias/{periciaId} {
      allow read: if estaAutenticado();
      allow write: if false;
    }
    match /elementos/{elementoId} {
      allow read: if estaAutenticado();
      allow write: if false;

      match /poderes/{poderId} {
        allow read: if estaAutenticado();
        allow write: if false;
      }
    }
    match /itens/{itemId} {
      allow read: if estaAutenticado();
      allow write: if false;
    }
    match /constantes/{constanteId} {
      allow read: if estaAutenticado();
      allow write: if false;
    }

    // ---- Perfil do usuário ----
    match /usuarios/{uid} {
      allow read, write: if ehDono(uid);
    }

    // ---- Campanhas ----
    match /campanhas/{campanhaId} {
      // Leitura aberta a qualquer usuário autenticado: quem vai entrar com
      // um código de convite precisa conseguir localizar a campanha pelo
      // `codigo_convite` ANTES de fazer parte de `jogadores_uids`.
      allow read: if estaAutenticado();

      allow create: if estaAutenticado()
        && request.resource.data.mestre_id == request.auth.uid
        && request.resource.data.jogadores_uids == []
        && request.resource.data.nome is string
        && request.resource.data.nome.size() > 0;

      // O mestre pode atualizar qualquer campo. Quem não é mestre só pode
      // alterar `jogadores_uids` (e `atualizado_em` junto), e só de duas
      // formas: ADICIONAR o próprio uid (entrar com código) ou REMOVER
      // o próprio uid (sair da campanha) -- nunca mexer no uid de outra
      // pessoa, nem tocar em nome/descrição/imagem/mestre_id/codigo_convite.
      allow update: if estaAutenticado() && (
        ehDono(resource.data.mestre_id)
        || (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['jogadores_uids', 'atualizado_em'])
          && request.resource.data.jogadores_uids.hasAll(resource.data.jogadores_uids)
          && request.resource.data.jogadores_uids.hasOnly(resource.data.jogadores_uids.concat([request.auth.uid]))
        )
        || (
          // Sair da campanha: o array novo só pode ter "perdido" o próprio
          // uid em relação ao antigo, nada mais mudou nele.
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['jogadores_uids', 'atualizado_em'])
          && resource.data.jogadores_uids.hasAll(request.resource.data.jogadores_uids)
          && resource.data.jogadores_uids.hasOnly(request.resource.data.jogadores_uids.concat([request.auth.uid]))
        )
      );

      allow delete: if ehDono(resource.data.mestre_id);
    }

    // ---- Fichas de personagem ----
    match /personagens/{personagemId} {
      allow read: if ehDono(resource.data.dono_uid);
      allow create: if ehDono(request.resource.data.dono_uid);
      allow update, delete: if ehDono(resource.data.dono_uid);

      // Acesso do Mestre (leitura da mesa inteira + aprovar/recusar
      // Ascensão) NÃO é feito por regras aqui -- ver comentário no topo
      // deste arquivo sobre api/mestre_campanha_personagens.py e
      // api/responder_ascensao.py.
      //
      // TODO (endurecimento): restringir escrita do dono para excluir o
      // bloco `calculado`, que deveria ser exclusivo de um endpoint com
      // Admin SDK (mesma ideia já aplicada em responder_ascensao.py).
    }
  }
}
